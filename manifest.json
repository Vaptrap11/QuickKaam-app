"related_applications": [],
"prefer_related_applications": false,
"display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
"launch_handler": {
"client_mode": ["focus-existing", "auto"]
},
"edge_side_panel": {
"preferred_width": 400
},
"note_taking": {
"new_note_url": "/quick-note"
},
"share_target": {
"action": "/share-target",
"method": "POST",
"enctype": "multipart/form-data",
"params": {
"title": "title",
"text": "text",
"url": "url",
"files": [
{
"name": "file",
"accept": ["image/*", "application/pdf"]
}
]
}
},
"file_handlers": [
{
"action": "/open-file",
"accept": {
"image/*": [".jpg", ".jpeg", ".png", ".gif"],
"application/pdf": [".pdf"],
"text/plain": [".txt"]
}
],
}
{
"protocol_handlers": [
"protocol": "web+quickkaam",
"url": "/protocol/%s"
}
],
"url_handlers": [
{
"origin": "https://quickkaam.app",
"paths": ["/jobs/*", "/profile/*", "/chat/*"]
}
],
{
"scope_extensions": [
"origin": "https://api.quickkaam.app"
}
],
"background_color_dark": "#121212",
"theme_color_dark": "#1E3A5F",
"icons_dark": [
{
"src": "/icons/icon-dark-192x192.png",
"sizes": "192x192",
"type": "image/png"
},
{
"src": "/icons/icon-dark-512x512.png",
"sizes": "512x512",
"type": "image/png"
}
],
"serviceworker": {
"src": "/sw.js",
"scope": "/",
"update_via_cache": "all"
},
"features": [
"Cross-platform",
"Oﬄine support",
"Push notifications",
"Background sync",
"Installable"
]
}
